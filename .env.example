# Copy this file to .env and fill in your values

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Default LLM provider: "openai" or "claude" ---
DEFAULT_PROVIDER=claude

# --- Supabase (same as Module 1) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...

# --- Memory settings ---
SESSION_MEMORY_MAX_TURNS=20       # max messages kept in session memory
PERSISTENT_MEMORY_MAX_ITEMS=50    # max memory items per session in DB

# --- RAG settings ---
RAG_TOP_K=5
RAG_THRESHOLD=0.3

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8001
